{
  "version": "1.5.0",
  "extends": [],
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noConstAssign": "error",
        "noConstantCondition": "error",
        "noInvalidBuiltinInstantiator": "error",
        "noInvalidConstructorSuper": "error",
        "noInvalidNewBuiltin": "error",
        "noNonoctalDecimalEscape": "error",
        "noPrecisionLoss": "error",
        "noSelfAssign": "error",
        "noSwitchDeclarations": "error",
        "noUndeclaredVariables": "error",
        "noUnreachable": "error",
        "noUnreachableSuper": "error"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn",
        "noDangerouslySetInnerHtmlWithChildren": "error"
      },
      "style": {
        "noImplicitBoolean": "warn",
        "noParameterAssign": "warn",
        "useAsConstAssertion": "warn",
        "useBlockStatements": "warn",
        "useConst": "warn",
        "useDefaultParameterLast": "warn",
        "useEnumInitializers": "warn",
        "useExplicitLengthCheck": "warn",
        "useExplicitUndefined": "warn",
        "useLiteralKeys": "warn",
        "useNumericLiterals": "warn",
        "useSelfClosingElements": "error",
        "useShorthandAssign": "warn",
        "useSingleVarDeclarator": "warn",
        "useTemplate": "warn"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noExcessiveNestedTestSuites": "warn",
        "noForEach": "off",
        "noMultipleClassesPerFile": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noAsyncPromiseExecutor": "error",
        "noCatchAssign": "error",
        "noClassAssign": "error",
        "noCommentText": "off",
        "noCompareNegZero": "error",
        "noControlCharactersInRegex": "error",
        "noDebugger": "warn",
        "noDuplicateAtImportRules": "error",
        "noDuplicateBrandCheck": "error",
        "noDuplicateClassMembers": "error",
        "noDuplicateJsxProps": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noEmptyBlockStatements": "warn",
        "noExplicitAny": "warn",
        "noFallthroughSwitchClause": "error",
        "noFunctionAssign": "error",
        "noGlobalAssign": "error",
        "noImportAssign": "error",
        "noMisleadingCharacterClass": "error",
        "noMisleadingInstantiator": "error",
        "noMissingNewInSuper": "error",
        "noProtoAccess": "error",
        "noRedeclare": "error",
        "noShadow": "warn",
        "noShadowRestrictedNames": "error",
        "noUnsafeDeclarationMerging": "error",
        "noUnsafeNegation": "error",
        "useAwait": "warn",
        "useGetterReturn": "error",
        "useIsNan": "error",
        "useValidTypeof": "error",
        "useYield": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentSize": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      "build",
      "coverage",
      ".env*"
    ]
  },
  "javascript": {
    "formatter": {
      "bracketSpacing": true,
      "breakChainedMemberExpressions": "smartline",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "singleQuote": false,
      "trailingComma": "all",
      "arrowParentheses": "always"
    }
  }
}
