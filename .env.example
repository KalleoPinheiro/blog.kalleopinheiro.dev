# ── Required ──────────────────────────────────────────────────────────────────
# Full public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://example.com

# ── Database ───────────────────────────────────────────────────────────────────
# Pooled connection URL — used by Prisma adapter at runtime (pgBouncer on Supabase port 6543)
DATABASE_URL=postgresql://user:changeme@localhost:5432/personal_blog_dev
# Direct connection URL — used by Prisma CLI for migrations only (Supabase port 5432)
# For local dev: same as DATABASE_URL. For Supabase: use the direct (non-pooled) URL.
DIRECT_URL=postgresql://user:changeme@localhost:5432/personal_blog_dev

# Supabase direct — used by Prisma migrations only
# For Supabase, use port 5432 without pgbouncer
DIRECT_URL=postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# PostgreSQL credentials (used by docker-compose for local dev)
# Change these for your local environment
DB_USER=user
DB_PASSWORD=changeme
DB_NAME=personal_blog_dev
DB_PORT=5432

# ── Optional — have defaults ───────────────────────────────────────────────────
# Runtime environment (development | test | production)
NODE_ENV=development

# Application version — injected by CI/CD; falls back to "dev" locally
APP_VERSION=dev

# Set to "true" to expose Swagger UI at /api/docs (leave "false" in production)
ENABLE_API_DOCS=false
