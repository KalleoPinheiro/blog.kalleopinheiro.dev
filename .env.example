# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/blog"
# For development with SQLite:
# DATABASE_URL="file:./prisma/dev.db"

# Next.js Configuration
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# NextAuth.js v5 Configuration
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# GitHub OAuth (optional)
# GITHUB_ID="your-github-oauth-id"
# GITHUB_SECRET="your-github-oauth-secret"

# Markdown Processing
MARKDOWN_PARSER="remark"
MARKDOWN_PLUGINS="emoji,gfm"

# Feature Flags
FEATURES_COMMENTS_ENABLED=true
FEATURES_SEARCH_ENABLED=true
FEATURES_DARK_MODE=true

# Swagger/OpenAPI Documentation
SWAGGER_ENABLED=true

# Logging
LOG_LEVEL="debug"

# Database Seeding
SEED_DATABASE=false

# Docker/Development
DOCKER_POSTGRES_USER="postgres"
DOCKER_POSTGRES_PASSWORD="password"
DOCKER_POSTGRES_DB="blog"
