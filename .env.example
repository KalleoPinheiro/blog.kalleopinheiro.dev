# ── Required ──────────────────────────────────────────────────────────────────
# Full public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://example.com

# ── Database ───────────────────────────────────────────────────────────────────
# Prisma database connection URL
# Change these for your local environment
DATABASE_URL=postgresql://user:changeme@localhost:5432/personal_blog_dev

# PostgreSQL credentials (used by docker-compose)
# Change these for your local environment
DB_USER=user
DB_PASSWORD=changeme
DB_NAME=personal_blog_dev
DB_PORT=5432

# ── Optional — have defaults ───────────────────────────────────────────────────
# Runtime environment (development | test | production)
NODE_ENV=development

# Application version — injected by CI/CD; falls back to "dev" locally
APP_VERSION=dev

# Set to "true" to expose Swagger UI at /api/docs (leave "false" in production)
ENABLE_API_DOCS=false
